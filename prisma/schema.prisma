datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-go"
  previewFeatures = ["clientExtensions"]
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  onboardingStep   Int?
  refreshTokens    RefreshToken[]
  categories       Category[]
  accounts         Account[]
  transactions     Transaction[]
  budgets          Budget[]
  customizations   UserCustomization?
  emis             Emi[]
}

model RefreshToken {
  id        String @id @default(uuid())
  token     String @unique
  expiresAt DateTime
  userId    String
  user      User   @relation(fields: [userId], references: [id])
}

model Category {
  id      String @id @default(uuid())
  userId  String
  name    String
  type    String
  color   String?
  icon    String?
  user    User   @relation(fields: [userId], references: [id])
  transactions Transaction[]
  budgets   Budget[]
  emis      Emi[]
}

model Account {
  id      String @id @default(uuid())
  userId  String
  name    String
  type    String
  user    User   @relation(fields: [userId], references: [id])
  transactions Transaction[]
  emis         Emi[]
}

model Transaction {
  id         String @id @default(uuid())
  userId     String
  categoryId String
  accountId  String
  amount     Float
  type       String
  notes      String?
  date       DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  category  Category  @relation(fields: [categoryId], references: [id])
  account   Account   @relation(fields: [accountId], references: [id])
}

model Budget {
  id          String @id @default(uuid())
  userId      String
  categoryId  String
  periodType  String
  limitAmount Float
  startDate   DateTime
  endDate     DateTime

  user       User     @relation(fields: [userId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])
}

model UserCustomization {
  id       String @id @default(uuid())
  userId   String @unique
  currency String?
  theme    String?
  user     User   @relation(fields: [userId], references: [id])
}

model Emi {
  id          String    @id @default(uuid())
  userId      String
  amount      Float
  type        String
  categoryId  String?
  accountId   String?
  date        DateTime
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  account     Account?  @relation(fields: [accountId], references: [id])
}

